#!/usr/bin/env bash
#
# Odoo Demo Database Feeder
# -------------------------
# A friendly launcher that lets a (non-technical) sales person populate an Odoo
# demo database with realistic data for a given industry / scope, driven by the
# Antigravity AI agent (agy).
#
# By default the agent runs NON-INTERACTIVELY and inside an OS-level sandbox
# (bubblewrap) so its only real capability is to call the CRUD tool against the
# target database. Pass -i / --interactive to drive agy interactively instead.
#
set -euo pipefail

# --------------------------------------------------------------------------- #
# Configuration
# --------------------------------------------------------------------------- #
# Public GitHub repo (owner/repo) holding the demo skills, pulled via `npx skills`.
# Leave empty to skip the remote skills refresh.
SKILLS_REPO="odoo-ps/odoo-feeder"

CRUD_TOOL="${CRUD_TOOL:-$HOME/.local/share/odoo-demo-feeder/odoo_crud.py}"
AGY_MODEL="${AGY_MODEL:-gemini-3-pro}"
AGY_TIMEOUT="${AGY_TIMEOUT:-20m}"   # headless print-mode budget (research+install+imports)

INTERACTIVE=0
PLAN=0
GAVE_ARGS=0

# Values may come from flags (below) or from environment variables of the same
# name. Anything still empty after parsing is asked for interactively.
ODOO_URL="${ODOO_URL:-}"
ODOO_LOGIN="${ODOO_LOGIN:-}"
ODOO_SECRET="${ODOO_SECRET:-}"
ODOO_DB="${ODOO_DB:-}"
ODOO_SCOPE="${ODOO_SCOPE:-}"
COMPANY_NAME="${COMPANY_NAME:-}"
COMPANY_SITE="${COMPANY_SITE:-}"
EXTRA="${EXTRA:-}"
ODOO_SIZE="${ODOO_SIZE:-}"   # small | medium | big (dataset volume)

# A sales "template": a free-text block (pasted or loaded from --template FILE)
# describing the demo to build. It is passed to the AI verbatim — never parsed —
# so any key the sales person writes is understood by the agent.
TEMPLATE_FILE="${TEMPLATE_FILE:-}"   # path to a template file (non-interactive load)
TEMPLATE_TEXT="${TEMPLATE_TEXT:-}"   # raw template contents

# --------------------------------------------------------------------------- #
# Colors (Odoo brand) — degrade gracefully when no TTY / NO_COLOR
# --------------------------------------------------------------------------- #
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    PURPLE=$'\e[38;5;97m'   # ~ Odoo #714B67
    TEAL=$'\e[38;5;37m'
    BOLD=$'\e[1m'
    DIM=$'\e[2m'
    RED=$'\e[31m'
    GREEN=$'\e[32m'
    RESET=$'\e[0m'
else
    PURPLE=""; TEAL=""; BOLD=""; DIM=""; RED=""; GREEN=""; RESET=""
fi

info()  { printf '%s\n' "${TEAL}$*${RESET}"; }
warn()  { printf '%s\n' "${RED}! $*${RESET}" >&2; }
die()   { printf '%s\n' "${RED}✖ $*${RESET}" >&2; exit 1; }

# --------------------------------------------------------------------------- #
# UI helpers — use `gum` for a nicer interface when it is available and we have a
# TTY, and degrade to plain `read` prompts otherwise. Every helper prints its
# result on stdout (so it can be captured with $(...)) and its UI on stderr, so
# the two never mix in the captured value.
# --------------------------------------------------------------------------- #
HAS_GUM=0
if command -v gum >/dev/null 2>&1 && [[ -t 0 && -t 2 ]]; then HAS_GUM=1; fi
export GUM_INPUT_PROMPT_FOREGROUND="#714B67"   # Odoo purple accent

ui_input() {  # ui_input <label> [placeholder]
    if [[ "$HAS_GUM" -eq 1 ]]; then
        gum input --prompt "$1 " --placeholder "${2:-}"
    else
        local v; read -r -p "  $1${2:+ ($2)}: " v; printf '%s' "$v"
    fi
}
ui_password() {  # ui_password <label>
    if [[ "$HAS_GUM" -eq 1 ]]; then
        gum input --password --prompt "$1 "
    else
        local v; read -r -s -p "  $1 " v; printf '\n' >&2; printf '%s' "$v"
    fi
}
ui_choose() {  # ui_choose <header> <option>...  -> prints the chosen option
    local header="$1"; shift
    if [[ "$HAS_GUM" -eq 1 ]]; then
        gum choose --header "$header" "$@"
    else
        local opt i=1
        printf '  %s\n' "$header" >&2
        for opt in "$@"; do printf '    %d) %s\n' "$i" "$opt" >&2; i=$((i+1)); done
        local n; read -r -p "  Choice [1]: " n; n="${n:-1}"
        if [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=$# )); then
            printf '%s' "${!n}"
        else
            printf '%s' "$1"
        fi
    fi
}
ui_write() {  # ui_write [placeholder]  -> prints the pasted multi-line text
    if [[ "$HAS_GUM" -eq 1 ]]; then
        # In gum ≥0.16, Enter submits and Ctrl+J inserts a newline; a pasted block
        # keeps its own newlines, so paste then press Enter.
        gum write --placeholder "${1:-Paste here…}" --width 0 --height 18 \
                  --header "Paste, then Enter to submit (Ctrl+J for a new line)"
    else
        printf '  %s\n' "${1:-Paste your text, then press Ctrl+D when done:}" >&2
        cat
    fi
}
ui_header() {  # ui_header <text>
    if [[ "$HAS_GUM" -eq 1 ]]; then
        gum style --foreground "#714B67" --bold "$*"
    else
        info "$*"
    fi
}

# Validate an Odoo URL: must be http(s), and never the public odoo.com site.
# Returns non-zero (and warns) when the URL is not acceptable.
check_url() {
    local url="$1" host
    if [[ ! "$url" =~ ^https?:// ]]; then
        warn "The URL must start with http:// or https://"
        return 1
    fi
    host="${url#*://}"; host="${host%%/*}"; host="${host%%:*}"
    host="$(printf '%s' "$host" | tr '[:upper:]' '[:lower:]')"
    if [[ "$host" == "odoo.com" || "$host" == "www.odoo.com" ]]; then
        warn "For safety, the public odoo.com production site is blocked."
        warn "Use a customer database (e.g. *.odoo.com) or a dedicated server."
        return 1
    fi
    return 0
}

print_logo() {
    printf '\n%s' "$PURPLE$BOLD"
    cat <<'LOGO'
   ██████      ██  ██████   ██████
  ██    ██     ██ ██    ██ ██    ██
  ██    ██ ██████ ██    ██ ██    ██
  ██    ██ ██  ██ ██    ██ ██    ██
   ██████  ██████  ██████   ██████
LOGO
    printf '%s\n' "$RESET"
    printf '%s\n' "${PURPLE}${BOLD}   Demo Database Feeder${RESET}"
    printf '%s\n\n' "${DIM}   Populate a demo database with realistic data, powered by AI.${RESET}"
}

usage() {
    cat <<USAGE
Usage: odoo-demo-feeder [options]

Any value not passed as a flag (or set as an environment variable) is asked for
interactively. Passing at least one value flag runs non-interactively (optional
fields are simply skipped when omitted).

Connection:
  --url URL             Odoo URL (blocked: odoo.com / www.odoo.com)
  --login USER          Login (email or user)          [ODOO_LOGIN]
  --secret SECRET       API key or password            [ODOO_SECRET]
  --db NAME             Database name (needed for localhost / self-hosted) [ODOO_DB]

Content:
  --scope TEXT          Industry / scope, e.g. "Bakery"  [ODOO_SCOPE]
  --size SIZE           Dataset volume: small | medium | big (default medium) [ODOO_SIZE]
  --company NAME        Customer company to research     [COMPANY_NAME]
  --website URL         Customer website to research     [COMPANY_SITE]
  --notes TEXT          Extra free-text instructions for the AI  [EXTRA]
                        e.g. "also create 5 sales orders and a few invoices"
  --template FILE       Load a template file describing the demo to build and
                        pass it to the AI verbatim (see the template block below).
                        Interactively, you can paste a template instead.

A template is a free-text block the AI reads directly — write any keys you like:
  name: Maison Rorive demo
  website: https://www.maisonrorive.be
  company_name: Maison Rorive
  country: BE
  apps: [sale_management, crm, website, helpdesk]
  data_size: big
  override_model_size: {product.product: 100, crm.lead: 30}
  configuration: enable pricelists, multi-currency, default sales team "Retail"

Other:
  -i, --interactive     Drive the AI agent interactively (advanced).
      --plan            Review a plan and approve it before any change is made
                        (implies interactive).
  -h, --help            Show this help.

Example:
  odoo-demo-feeder --url http://localhost:8069 --login admin --secret admin \\
    --db mydb --scope "Bakery" --company "Maison Rorive" \\
    --website https://www.maisonrorive.be
USAGE
}

# --------------------------------------------------------------------------- #
# Argument parsing
# --------------------------------------------------------------------------- #
need_val() { [[ -n "${2:-}" ]] || die "Option $1 needs a value."; }
while [[ $# -gt 0 ]]; do
    case "$1" in
        --url)                 need_val "$1" "${2:-}"; ODOO_URL="$2";     GAVE_ARGS=1; shift 2 ;;
        --login|--user)        need_val "$1" "${2:-}"; ODOO_LOGIN="$2";   GAVE_ARGS=1; shift 2 ;;
        --secret|--key|--password) need_val "$1" "${2:-}"; ODOO_SECRET="$2"; GAVE_ARGS=1; shift 2 ;;
        --db|--database)       need_val "$1" "${2:-}"; ODOO_DB="$2";      GAVE_ARGS=1; shift 2 ;;
        --scope)               need_val "$1" "${2:-}"; ODOO_SCOPE="$2";   GAVE_ARGS=1; shift 2 ;;
        --size)                need_val "$1" "${2:-}"; ODOO_SIZE="$2";    GAVE_ARGS=1; shift 2 ;;
        --company)             need_val "$1" "${2:-}"; COMPANY_NAME="$2"; GAVE_ARGS=1; shift 2 ;;
        --website)             need_val "$1" "${2:-}"; COMPANY_SITE="$2"; GAVE_ARGS=1; shift 2 ;;
        --notes|--extra)       need_val "$1" "${2:-}"; EXTRA="$2";        GAVE_ARGS=1; shift 2 ;;
        --template)            need_val "$1" "${2:-}"; TEMPLATE_FILE="$2"; GAVE_ARGS=1; shift 2 ;;
        -i|--interactive)      INTERACTIVE=1; shift ;;
        --plan)                PLAN=1; INTERACTIVE=1; shift ;;
        -h|--help)             usage; exit 0 ;;
        *) usage; die "Unknown option: $1" ;;
    esac
done

# --------------------------------------------------------------------------- #
# Pre-flight checks
# --------------------------------------------------------------------------- #
command -v agy   >/dev/null 2>&1 || die "agy (Antigravity CLI) is not installed. Run install.sh first."
command -v bwrap >/dev/null 2>&1 || die "bubblewrap (bwrap) is not installed. Run install.sh first."
command -v python3 >/dev/null 2>&1 || die "python3 is not installed. Run install.sh first."
[[ -f "$CRUD_TOOL" ]] || die "CRUD tool not found at $CRUD_TOOL. Run install.sh first."

# agy must already be signed in: its Google OAuth flow (browser + paste a code)
# cannot run headless inside the sandbox, so an unauthenticated run would just
# hang until the timeout. Fail fast with clear instructions instead.
if [[ -z "${ANTIGRAVITY_TOKEN:-}" && ! -s "$HOME/.gemini/oauth_creds.json" ]]; then
    die "agy is not signed in yet.
   Run 'agy' once and sign in with your Google account, then re-run.
   (For unattended / CI use, set the ANTIGRAVITY_TOKEN environment variable.)"
fi

print_logo

# --------------------------------------------------------------------------- #
# Step 1 — collect connection details
# --------------------------------------------------------------------------- #
ui_header "Step 1/3 — Tell me about the database you want to fill."
echo

# URL — prompt (with a retry loop) only if not supplied; always validate.
if [[ -z "$ODOO_URL" ]]; then
    while :; do
        ODOO_URL="$(ui_input "Odoo URL" "e.g. https://mycompany.odoo.com")"
        ODOO_URL="${ODOO_URL%/}"
        check_url "$ODOO_URL" && break
        ODOO_URL=""
    done
else
    ODOO_URL="${ODOO_URL%/}"
    check_url "$ODOO_URL" || die "Refusing to use this URL."
fi

[[ -n "$ODOO_LOGIN" ]]  || ODOO_LOGIN="$(ui_input "Login (email or user)")"
[[ -n "$ODOO_LOGIN" ]]  || die "A login is required."

[[ -n "$ODOO_SECRET" ]] || ODOO_SECRET="$(ui_password "API key or password")"
[[ -n "$ODOO_SECRET" ]] || die "An API key or password is required."

# A --template FILE takes precedence: load it verbatim, no content prompts.
if [[ -n "$TEMPLATE_FILE" ]]; then
    [[ -f "$TEMPLATE_FILE" ]] || die "Template file not found: $TEMPLATE_FILE"
    TEMPLATE_TEXT="$(cat "$TEMPLATE_FILE")"
    [[ -n "$TEMPLATE_TEXT" ]] || die "Template file is empty: $TEMPLATE_FILE"
fi

# --------------------------------------------------------------------------- #
# Content — how the demo should be built. Two ways in:
#   • Template : paste (or --template FILE) a free-text block; it goes to the AI
#                verbatim, so any key the sales person writes is understood.
#   • Scratch  : answer a few questions (scope, size, company, website, notes).
# The template chooser only appears when running interactively (no flags given).
# --------------------------------------------------------------------------- #
if [[ -z "$TEMPLATE_TEXT" && "$GAVE_ARGS" -eq 0 ]]; then
    echo
    choice="$(ui_choose "Do you want to use a template or start from scratch?" \
        "Paste a template" "Start from scratch")"
    if [[ "$choice" == "Paste a template" ]]; then
        echo
        info "  Paste your template below. Example keys:"
        printf '%s\n' "${DIM}    name / website / company_name / country / apps / data_size /
    override_model_size / configuration — plus any free text.${RESET}"
        TEMPLATE_TEXT="$(ui_write "Paste your template here…")"
        [[ -n "$(printf '%s' "$TEMPLATE_TEXT" | tr -d '[:space:]')" ]] || die "The template was empty."
    fi
fi

# Scratch / flag-driven content: gather the individual fields. Skipped entirely
# when a template was provided (the template already describes the demo).
if [[ -z "$TEMPLATE_TEXT" ]]; then
    [[ -n "$ODOO_SCOPE" ]] || ODOO_SCOPE="$(ui_input "Scope / industry" "e.g. Plumbing, Commerce, Restaurant")"
    [[ -n "$ODOO_SCOPE" ]] || die "A scope is required (or use a template)."

    # Optional fields — only asked when running fully interactively (no flags).
    # The database name matters for localhost / self-hosted (SaaS auto-detects it).
    if [[ "$GAVE_ARGS" -eq 0 ]]; then
        [[ -n "$ODOO_DB" ]]      || ODOO_DB="$(ui_input "Database name" "optional — needed for localhost, Enter to auto-detect")"
        [[ -n "$ODOO_SIZE" ]]    || ODOO_SIZE="$(ui_choose "Dataset size" small medium big)"
        [[ -n "$COMPANY_NAME" ]] || COMPANY_NAME="$(ui_input "Customer company name" "optional, Enter to skip")"
        [[ -n "$COMPANY_SITE" ]] || COMPANY_SITE="$(ui_input "Customer website" "optional, e.g. https://acme.com")"
        [[ -n "$EXTRA" ]]        || EXTRA="$(ui_input "Anything else the AI should do?" "optional, e.g. also create 5 sales orders")"
    fi

    # Normalise the dataset size (default medium; fall back on anything unexpected).
    ODOO_SIZE="$(printf '%s' "${ODOO_SIZE:-medium}" | tr '[:upper:]' '[:lower:]')"
    case "$ODOO_SIZE" in
        small|medium|big) ;;
        *) warn "Unknown size '$ODOO_SIZE' — using 'medium'."; ODOO_SIZE="medium" ;;
    esac
fi

echo
info "  → Target  : $ODOO_URL"
[[ -n "$ODOO_DB" ]]      && info "  → Database: $ODOO_DB"
if [[ -n "$TEMPLATE_TEXT" ]]; then
    info "  → Source  : template ($(printf '%s' "$TEMPLATE_TEXT" | grep -c . ) non-empty lines)"
else
    info "  → Scope   : $ODOO_SCOPE"
    info "  → Size    : $ODOO_SIZE"
    [[ -n "$COMPANY_NAME" ]] && info "  → Company : $COMPANY_NAME"
    [[ -n "$COMPANY_SITE" ]] && info "  → Website : $COMPANY_SITE"
    [[ -n "$EXTRA" ]]        && info "  → Notes   : $(printf '%s' "$EXTRA" | tr '\n' ' ')"
fi
echo

export ODOO_URL ODOO_LOGIN ODOO_SECRET ODOO_DB ODOO_SCOPE ODOO_SIZE COMPANY_NAME COMPANY_SITE

# --------------------------------------------------------------------------- #
# Step 2 — make sure the skills are up to date
# --------------------------------------------------------------------------- #
ui_header "Step 2/3 — Updating the AI skills..."

# Refresh from the public repo, quietly (npx skills is very chatty), targeting
# Antigravity only and copying files (symlinks would break inside the sandbox).
if [[ -n "$SKILLS_REPO" ]] && command -v npx >/dev/null 2>&1; then
    if npx -y skills add "$SKILLS_REPO" --global --agent antigravity --skill '*' --copy -y >/dev/null 2>&1; then
        info "  ✔ Skills up to date ($SKILLS_REPO)"
    else
        warn "Could not refresh skills from $SKILLS_REPO — using the installed copy."
    fi
fi

# --- Restrict the agent to ONLY the CRUD tool ------------------------------- #
# Install a single-name wrapper so the permission rule matches it exactly (a
# rule on 'python3' would auto-approve any Python). Then allow only that command
# in agy's settings — plus web research and file access the skill needs. Every
# other command falls outside the allowlist and is not auto-approved. bwrap
# remains the hard OS backstop underneath.
CRUD_WRAPPER="$HOME/.local/bin/odoo-crud"
mkdir -p "$HOME/.local/bin"
cat > "$CRUD_WRAPPER" <<CRUD
#!/usr/bin/env bash
exec python3 "$CRUD_TOOL" "\$@"
CRUD
chmod +x "$CRUD_WRAPPER"

# Merge our allow-rules into agy's global settings (preserving anything already
# there). Strict, non-regex matching (agy default) — 'command(odoo-crud)' matches
# any 'odoo-crud <subcommand>' invocation.
AGY_SETTINGS="$HOME/.gemini/antigravity-cli/settings.json"
mkdir -p "$(dirname "$AGY_SETTINGS")"
if python3 - "$AGY_SETTINGS" <<'PY'
import json, sys
path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
    if not isinstance(data, dict):
        data = {}
except Exception:
    data = {}
allow = data.setdefault("permissions", {}).setdefault("allow", [])
for rule in ("command(odoo-crud)", "read_url(*)", "read_file(*)", "write_file(*)"):
    if rule not in allow:
        allow.append(rule)
with open(path, "w") as f:
    json.dump(data, f, indent=2)
PY
then
    info "  ✔ Agent restricted to the 'odoo-crud' tool"
else
    warn "Could not write agy permissions; the run may prompt for approvals."
fi
echo

# --------------------------------------------------------------------------- #
# Step 3 — run the AI agent
# --------------------------------------------------------------------------- #
ui_header "Step 3/3 — Populating the database. This can take a few minutes..."
echo

# Build the "what to build" section. Two shapes:
#   • Template mode : pass the pasted block VERBATIM with a legend telling the
#     agent how to read each key. The template drives size, apps, etc., so we do
#     NOT inject the hardcoded size line or a fixed module list here.
#   • Scratch mode  : the classic scope/size/company description.
if [[ -n "$TEMPLATE_TEXT" ]]; then
    TARGET_DESC="The sales person provided the TEMPLATE below describing the demo to build.
Treat it as the source of truth and follow every key you recognise:
  • name                 → a human label for the demo (not data to create)
  • website / company_name → the real company to research (research the site FIRST)
  • country              → set this country (and its currency) on res.company
  • apps                 → install EXACTLY these apps (map friendly names to the
                           technical module names, pull in dependencies) in ONE
                           'install-modules' call
  • data_size            → the overall scale (small/medium/big); apply it
                           consistently to every model via the skill's anchor +
                           ratios. If absent, use 'medium'.
  • override_model_size  → for the models listed here, use EXACTLY these record
                           counts instead of the ratio-derived numbers
  • configuration        → apply these settings/config after the data is imported
Any other key or free text: follow it as an instruction.

===== TEMPLATE =====
${TEMPLATE_TEXT}
===== END TEMPLATE ====="
    SIZE_DIRECTIVE=""
    INSTALL_HINT="install EXACTLY the apps listed in the template (mapped to their
   technical module names, with dependencies) in ONE call, e.g.
   'install-modules sale_management crm website ...'"
elif [[ -n "$COMPANY_SITE" || -n "$COMPANY_NAME" ]]; then
    TARGET_DESC="Build the data for this real company (research its website first):
  Company: ${COMPANY_NAME:-(name not given)}
  Website: ${COMPANY_SITE:-(website not given)}
  Industry / scope: ${ODOO_SCOPE}"
    SIZE_DIRECTIVE="Target dataset size: ${ODOO_SIZE}. Apply this size consistently to EVERY model you
populate, using the anchor + ratios in the skill's 'Dataset size' section — do not
guess the volume, and don't leave some models tiny while others are large.

"
    INSTALL_HINT="install every module you need
   in ONE call: 'install-modules crm stock sale_management account'"
else
    TARGET_DESC="No specific customer was given — generate coherent, generic demo
data for the \"${ODOO_SCOPE}\" industry."
    SIZE_DIRECTIVE="Target dataset size: ${ODOO_SIZE}. Apply this size consistently to EVERY model you
populate, using the anchor + ratios in the skill's 'Dataset size' section — do not
guess the volume, and don't leave some models tiny while others are large.

"
    INSTALL_HINT="install every module you need
   in ONE call: 'install-modules crm stock sale_management account'"
fi

REQUEST="You are populating an Odoo demo database for a sales demo.

Follow the 'odoo-demo-csv' skill: research the target, generate Odoo-import-ready
CSV files, and import them into the connected database.

${SIZE_DIRECTIVE}${TARGET_DESC}

Use ONLY this tool for every database operation (it reads the credentials from
environment variables, so never ask for them). Wherever the skill mentions
CRUD_TOOL, run:

    odoo-crud <command> [options]

This is the ONLY shell command you are permitted to run — other commands are
blocked. It can read and write files in the current directory and fetch web
pages for research.

Available commands: auth-check | search-read | create | write | unlink | call |
models | fields | import-preview | import-csv. Each prints JSON
{\"ok\": true|false, ...} so you can check results and recover from errors.

Be verbose: announce each step before doing it and print a one-line result after
each command, so the person watching sees clear progress.

Every command is synchronous — never wait or pause for an operation to finish.
To install modules, use ONE call: 'odoo-crud install-modules <names...>' — it
installs AND confirms the modules before returning, so there is nothing to wait
for. Work in one continuous pass and only stop after you print the SUMMARY line.

Steps:
1. Run auth-check first and stop with a clear message if it fails.
2. Inspect the database ('models', 'fields'), then ${INSTALL_HINT} (it installs
   and confirms before returning — do not wait). Configure the company's
   country/currency from your research.
3. Generate the CSV files defined by the skill, write each to a file in the
   current directory, and import them in dependency order with 'import-csv'.
4. If an import fails, use 'import-preview', 'fields' and 'models' to find out
   why, fix the CSV, and retry.
Finish by printing one line that starts with 'SUMMARY:' describing what you created."

# Append any extra free-text instructions from the sales person.
if [[ -n "$EXTRA" ]]; then
    REQUEST+="

Additional instructions from the sales person (follow these too when reasonable):
${EXTRA}"
fi

# Plan mode: make the agent lay out a plan and wait for approval before acting.
if [[ "$PLAN" -eq 1 ]]; then
    if [[ -n "$TEMPLATE_TEXT" ]]; then PLAN_SIZE="the template's data_size"; else PLAN_SIZE="'${ODOO_SIZE}'"; fi
    REQUEST="FIRST, present a short PLAN and WAIT for my approval before you change
anything. The plan must list: the modules you will install, the record counts per
model for ${PLAN_SIZE}, and the files you will create. Do NOT run any
create/import/install until I reply to approve.

${REQUEST}"
fi

# Scratch directory (writable workspace for the agent + the prompt file).
WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT

# The prompt goes to a file (never the command line) so it survives quoting and
# never lands in the process list. Credentials stay in the environment only.
printf '%s\n' "$REQUEST" > "$WORK/request.txt"

# agy needs a writable config/auth dir; make sure it exists so the bind succeeds.
mkdir -p "$HOME/.gemini" "$HOME/.cache"

# Make the skill visible to agy as a WORKSPACE skill (.agents/skills under the
# working dir). This is the unambiguous location agy reads, regardless of which
# global dir the skills CLI used. $WORK is the agent's --chdir root.
mkdir -p "$WORK/.agents/skills"
for src in "$HOME/.agents/skills" "$HOME/.gemini/antigravity/skills"; do
    [[ -d "$src" ]] && cp -r "$src/." "$WORK/.agents/skills/" 2>/dev/null || true
done

# Generate a self-contained launcher inside the scratch dir. It runs agy inside a
# bubblewrap jail: the whole system is read-only, only the scratch dir + agy's own
# config/cache are writable, sensitive home dirs are masked, network is on, and
# only the ODOO_* credentials are exposed. So the agent's only real capability is
# to run the CRUD tool against the target database.
#
# The heredoc is quoted ('LAUNCH') so nothing expands now: ODOO_* / AGY_MODEL /
# HOME are read from the environment at run time (inherited via `script`), keeping
# secrets out of this file on disk.
cat > "$WORK/launch.sh" <<'LAUNCH'
#!/usr/bin/env bash
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"

bwrap_args=(
    --ro-bind / /
    --dev /dev --proc /proc --tmpfs /tmp
    --bind "$HERE" "$HERE"
    --bind "$HOME/.gemini" "$HOME/.gemini"
    --bind "$HOME/.cache" "$HOME/.cache"
    --tmpfs "$HOME/.ssh"
    --chdir "$HERE"
    --share-net --unshare-pid --new-session --die-with-parent
    --setenv HOME "$HOME"
    --setenv PATH "$HOME/.local/bin:$PATH"
    --setenv ODOO_URL "$ODOO_URL"
    --setenv ODOO_LOGIN "$ODOO_LOGIN"
    --setenv ODOO_SECRET "$ODOO_SECRET"
    --setenv ODOO_SCOPE "$ODOO_SCOPE"
)
[[ -n "${ODOO_DB:-}" ]] && bwrap_args+=(--setenv ODOO_DB "$ODOO_DB")
[[ -n "${ANTIGRAVITY_TOKEN:-}" ]] && bwrap_args+=(--setenv ANTIGRAVITY_TOKEN "$ANTIGRAVITY_TOKEN")

if [[ "${MODE:-batch}" == "interactive" ]]; then
    exec bwrap "${bwrap_args[@]}" agy --sandbox --model "$AGY_MODEL" "$(cat "$HERE/request.txt")"
else
    exec bwrap "${bwrap_args[@]}" \
        agy -p "$(cat "$HERE/request.txt")" --model "$AGY_MODEL" --print-timeout "$AGY_TIMEOUT"
fi
LAUNCH
chmod +x "$WORK/launch.sh"
export AGY_MODEL AGY_TIMEOUT

if [[ "$INTERACTIVE" -eq 1 ]]; then
    # Interactive: the terminal is already a TTY, run the launcher directly.
    MODE=interactive "$WORK/launch.sh"
    exit $?
fi

# Non-interactive (default). agy's headless mode silently drops stdout under a
# non-TTY, so we attach the launcher to a pseudo-TTY, then strip ANSI escapes from
# the captured output. Prefer util-linux `script`; fall back to a tiny Python pty
# wrapper so no extra system package is required (python3 is already a dependency).
pty_run() {
    if command -v script >/dev/null 2>&1; then
        script -qec "$1" /dev/null
    else
        python3 - "$1" <<'PY'
import os, pty, sys
os._exit(os.waitstatus_to_exitcode(pty.spawn([sys.argv[1]])))
PY
    fi
}

LOG="$WORK/agy-output.log"
set +e
pty_run "$WORK/launch.sh" \
    | sed -u -r 's/\x1B\[[0-9;]*[A-Za-z]//g' | tr -d '\r' | tee "$LOG"
status=${PIPESTATUS[0]}
set -e

echo
if grep -q '^SUMMARY:' "$LOG" 2>/dev/null; then
    printf '%s\n' "${GREEN}✔ Done!${RESET}"
    grep '^SUMMARY:' "$LOG" | sed "s/^/  ${GREEN}/; s/\$/${RESET}/"
elif [[ "$status" -ne 0 ]]; then
    die "The AI agent exited with an error (code $status). See the output above."
else
    warn "The agent finished but produced no SUMMARY line — please review the output above."
fi
